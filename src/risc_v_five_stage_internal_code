`timescale 1ns / 1ps
module MEM_STAGE(
    input         clk,
    input         reset,
    input  [31:0] address,
    input  [1:0]  mem_control, // {mem_read, mem_write}
    input  [31:0] write_data,
    output [31:0] read_data
);

    (* ram_style = "block" *) reg [7:0] mem [0:1023]; // 1KB example

    // Combinational read: assemble little-endian word
    assign read_data = mem_control[1] ? { mem[address + 3], mem[address + 2], mem[address + 1], mem[address] } : 32'b0;

    // Synchronous write (non-blocking)
    always @(posedge clk) begin
        if (reset) begin
            // Optionally initialize memory or leave contents unchanged
            // For example purpose only:
            mem[4] <= 8'h01;
            mem[5] <= 8'h00;
            mem[6] <= 8'h00;
            mem[7] <= 8'h00;
        end else begin
            if (mem_control[0]) begin // mem_write
                mem[address + 0] <= write_data[ 7: 0];
                mem[address + 1] <= write_data[15: 8];
                mem[address + 2] <= write_data[23:16];
                mem[address + 3] <= write_data[31:24];
            end
        end
    end
endmodule

