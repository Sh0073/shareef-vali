module stalling_mux(
input [6:0]ex_control_temp,
input [1:0]mem_control_temp,
input [1:0]wb_control_temp,

input stall,

output [6:0]ex_control,
output [1:0]mem_control,
output [1:0]wb_control
    );
    
    assign ex_control=  stall?0:ex_control_temp;
    assign mem_control= stall?0:mem_control_temp;
    assign wb_control=  stall?0:wb_control_temp;

endmodule


`timescale 1ns / 1ps
module SIGN_EXTEND(
    input  [31:0] instruction,
    output reg [31:0] sign_ext_imm
);

    wire [6:0] opcode = instruction[6:0];

    always @(*) begin
        case (opcode)
            // I-type arithmetic / loads / JALR
            7'b0010011, // arithmetic immediate (ADDI, SLTI, SLTIU, XORI, ORI, ANDI, SLLI, SRLI/SRAI)
            7'b0000011, // loads
            7'b1100111: // JALR
            begin
                // sign-extend bits [31:20] for all I-type immediates
                sign_ext_imm = {{20{instruction[31]}}, instruction[31:20]};
            end

            // S-type (store): imm[11:5] in [31:25], imm[4:0] in [11:7]
            7'b0100011: begin
                sign_ext_imm = {{20{instruction[31]}}, instruction[31:25], instruction[11:7]};
            end

            // B-type (branch): imm bits scattered, always sign-extended
            7'b1100011: begin
                // imm[12] = inst[31], imm[11] = inst[7], imm[10:5]=inst[30:25], imm[4:1]=inst[11:8], imm[0]=0
                sign_ext_imm = {{19{instruction[31]}}, instruction[31], instruction[7], instruction[30:25], instruction[11:8], 1'b0};
            end

            // U-type (LUI/AUIPC): imm = inst[31:12] << 12 (no sign-extension beyond placing bits in high 20)
            7'b0110111, 7'b0010111: begin
                sign_ext_imm = {instruction[31:12], 12'b0};
            end

            // J-type (JAL)
            7'b1101111: begin
                // imm[20]=inst[31], imm[10:1]=inst[30:21], imm[11]=inst[20], imm[19:12]=inst[19:12], imm[0]=0
                sign_ext_imm = {{11{instruction[31]}},
                                instruction[31],
                                instruction[19:12],
                                instruction[20],
                                instruction[30:21],
                                1'b0};
            end

            default: begin
                sign_ext_imm = 32'b0;
            end
        endcase
    end

endmodule



`timescale 1ns / 1ps
module DECODE(
    input clk,
    input reset,

    input  [31:0] instruction,

    input         wb_reg_write,
    input  [4:0]  wb_rd,
    input  [31:0] wb_data,

    input         stall,

    // outputs
    output [6:0]  ex_control,
    output [1:0]  mem_control,
    output [1:0]  wb_control,

    output [31:0] rs1,
    output [31:0] rs2,
    output [31:0] immediate,
    output [31:0] rd_old,       // old value of rd for MAC (from REGFILE)

    output        unrecognized
);

    wire [6:0] ex_control_temp;
    wire [1:0] mem_control_temp;
    wire [1:0] wb_control_temp;

    wire [4:0] s1 = instruction[19:15];
    wire [4:0] s2 = instruction[24:20];
    wire [4:0] rd = instruction[11:7];

    // Register File Instance (read_rd is the current instruction's rd)
    REGFILE r1(
        .clk(clk),
        .reset(reset),
        .s1(s1),
        .s2(s2),
        .read_rd(rd),          // new read index for old rd
        .reg_write(wb_reg_write),
        .wb_rd(wb_rd),
        .wb_data(wb_data),
        .RS1(rs1),
        .RS2(rs2),
        .RD_OLD(rd_old)
    );

    // Control Unit
    CONTROL_UNIT c1(
        .opcode(instruction[6:0]),
        .ex_control(ex_control_temp),
        .mem_control(mem_control_temp),
        .wb_control(wb_control_temp),
        .unrecognized(unrecognized)
    );

    // Stall handling (if stall asserted, replace controls with 0 to insert bubble)
    stalling_mux st_unit(
        .ex_control_temp(ex_control_temp),
        .mem_control_temp(mem_control_temp),
        .wb_control_temp(wb_control_temp),
        .stall(stall),
        .ex_control(ex_control),
        .mem_control(mem_control),
        .wb_control(wb_control)
    );

    // Immediate generation
    SIGN_EXTEND se_unit(
        .instruction(instruction),
        .sign_ext_imm(immediate)
    );


endmodule

`timescale 1ns / 1ps
module ID_EX(
    input clk,
    input reset,

    input branch,

    // Inputs from DECODE stage
    input [4:0] id_rd,
    input [31:0] id_pc,
    input [31:0] id_rs1,
    input [31:0] id_rs2,
    input [31:0] id_immediate,
    input [31:0] id_rd_old,       // Old RD value (MAC)

    input [2:0] id_funct_3,
    input [6:0] id_funct_7,

    input [6:0] id_ex_control,
    input [1:0] id_mem_control,
    input [1:0] id_wb_control,

    input [4:0] id_Rs1,
    input [4:0] id_Rs2,
    input [6:0] id_opcode,

    // Outputs to EXECUTE stage
    output reg [4:0] ex_rd,
    output reg [31:0] ex_pc,
    output reg [31:0] ex_rs1,
    output reg [31:0] ex_rs2,
    output reg [31:0] ex_immediate,
    output reg [31:0] ex_rd_old,  // Pipelined old RD for MAC

    output reg [2:0] ex_funct_3,
    output reg [6:0] ex_funct_7,

    output reg [6:0] ex_ex_control,
    output reg [1:0] ex_mem_control,
    output reg [1:0] ex_wb_control,

    output reg [4:0] ex_Rs1,
    output reg [4:0] ex_Rs2,
    output reg [6:0] ex_opcode
);

    always @(posedge clk) begin
        if (reset | branch) begin
            ex_rd          <= 0;
            ex_pc          <= 0;
            ex_rs1         <= 0;
            ex_rs2         <= 0;
            ex_immediate   <= 0;
            ex_rd_old      <= 0;
            ex_funct_3     <= 0;
            ex_funct_7     <= 0;
            ex_ex_control  <= 0;
            ex_mem_control <= 0;
            ex_wb_control  <= 0;
            ex_Rs1         <= 0;
            ex_Rs2         <= 0;
            ex_opcode      <= 0;
        end else begin
            ex_rd          <= id_rd;
            ex_pc          <= id_pc;
            ex_rs1         <= id_rs1;
            ex_rs2         <= id_rs2;
            ex_immediate   <= id_immediate;
            ex_rd_old      <= id_rd_old;     // Pass MAC old RD value
            ex_funct_3     <= id_funct_3;
            ex_funct_7     <= id_funct_7;
            ex_ex_control  <= id_ex_control;
            ex_mem_control <= id_mem_control;
            ex_wb_control  <= id_wb_control;
            ex_Rs1         <= id_Rs1;
            ex_Rs2         <= id_Rs2;
            ex_opcode      <= id_opcode;
        end
    end

endmodule


`timescale 1ns / 1ps
module ALU_CONTROL(
    input  [1:0] alu_op,
    input  [2:0] funct_3,
    input  [6:0] funct_7,
    output reg [4:0] alu_control
);

always @(*) begin
    case(alu_op)
        2'b00: alu_control = 5'd0; // Load/Store ADD
        2'b01: alu_control = 5'd1; // Branch SUB
        2'b10: begin // R-type RV32I, RV32M, CNN
            case(funct_7)
                7'b0000000: case(funct_3)
                    3'b000: alu_control = 5'd0; // ADD
                    3'b001: alu_control = 5'd5; // SLL
                    3'b010: alu_control = 5'd8; // SLT
                    3'b011: alu_control = 5'd9; // SLTU
                    3'b100: alu_control = 5'd2; // XOR
                    3'b101: alu_control = 5'd6; // SRL
                    3'b110: alu_control = 5'd3; // OR
                    3'b111: alu_control = 5'd4; // AND
                    default: alu_control = 5'd0;
                endcase
                7'b0100000: case(funct_3)
                    3'b000: alu_control = 5'd1; // SUB
                    3'b101: alu_control = 5'd7; // SRA
                    default: alu_control = 5'd0;
                endcase
                7'b0000001: case(funct_3) // RV32M
                    3'b000: alu_control = 5'd10; // MUL
                    3'b001: alu_control = 5'd11; // MULH
                    3'b010: alu_control = 5'd12; // MULHSU
                    3'b011: alu_control = 5'd13; // MULHU
                    3'b100: alu_control = 5'd14; // DIV
                    3'b101: alu_control = 5'd15; // DIVU
                    3'b110: alu_control = 5'd16; // REM
                    3'b111: alu_control = 5'd17; // REMU
                    default: alu_control = 5'd0;
                endcase
                7'b0101010: case(funct_3) // CNN
                    3'b000: alu_control = 5'd18; // MAC
                    3'b001: alu_control = 5'd21; // RELU
                    3'b010: alu_control = 5'd19; // MAXPOOL
                    3'b011: alu_control = 5'd20; // AVGPOOL
                    default: alu_control = 5'd0;
                endcase
                default: alu_control = 5'd0;
            endcase
        end
        2'b11: begin // I-type
            case(funct_3)
                3'b000: alu_control = 5'd0; // ADDI
                3'b010: alu_control = 5'd8; // SLTI
                3'b011: alu_control = 5'd9; // SLTIU
                3'b100: alu_control = 5'd2; // XORI
                3'b110: alu_control = 5'd3; // ORI
                3'b111: alu_control = 5'd4; // ANDI
                3'b001: alu_control = 5'd5; // SLLI
                3'b101: alu_control = (funct_7==7'b0000000)?5'd6: (funct_7==7'b0100000)?5'd7:5'd0; // SRLI/SRAI
                default: alu_control = 5'd0;
            endcase
        end
        default: alu_control = 5'd0;
    endcase
end
endmodule
  
`timescale 1ns / 1ps
module ALU(
    input  [31:0] a,
    input  [31:0] b,
    input  [31:0] rd_in,     // old RD value for MAC
    input  [4:0]  control,   // 5-bit
    output reg [31:0] c
);

always @(*) begin
    case(control)
        // RV32I
        5'd0:  c = a + b;           
        5'd1:  c = a - b;           
        5'd2:  c = a ^ b;           
        5'd3:  c = a | b;           
        5'd4:  c = a & b;           
        5'd5:  c = a << b[4:0];     
        5'd6:  c = a >> b[4:0];     
        5'd7:  c = $signed(a) >>> b[4:0];
        5'd8:  c = ($signed(a) < $signed(b)) ? 1 : 0;
        5'd9:  c = (a < b) ? 1 : 0;
        // RV32M
        5'd10: c = a * b;
        5'd11: c = ($signed(a) * $signed(b)) >> 32;
        5'd12: c = ($signed(a) * b) >> 32;
        5'd13: c = (a * b) >> 32;
        5'd14: c = (b != 0) ? $signed(a)/$signed(b) : 32'hFFFFFFFF;
        5'd15: c = (b != 0) ? a / b : 32'hFFFFFFFF;
        5'd16: c = (b != 0) ? $signed(a)%$signed(b) : a;
        5'd17: c = (b != 0) ? a % b : a;
        // CNN
        5'd18: c = a * b + rd_in;       // MAC
        5'd19: c = (a > b) ? a : b;     // MAXPOOL
        5'd20: c = (a + b) >> 1;        // AVGPOOL
        5'd21: c = (a > 0) ? a : 0;     // RELU
        default: c = 0;
    endcase
end
endmodule


