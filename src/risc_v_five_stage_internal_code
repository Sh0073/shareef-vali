
`timescale 1ns / 1ps


module PC_MUX(
    input  wire [31:0] pc,
    input  wire [31:0] branch_address,
    input  wire [31:0] jump_address,
    input  wire        branch,
    input  wire        jump,
    output reg  [31:0] next_pc
);
  always @(*) begin
    if (branch)      next_pc = branch_address;
    else if (jump)   next_pc = jump_address;
    else             next_pc = pc + 32'd4;
  end
endmodule


`timescale 1ns / 1ps



module jump_detector_and_jump_address(


    input  wire [31:0] pc,
    input  wire [31:0] instruction,
    output wire        jump,
    output wire [31:0] jump_address
);
  wire [31:0] imm = {{12{instruction[31]}},
                     instruction[31],
                     instruction[19:12],
                     instruction[20],
                     instruction[30:21],
                     1'b0};
  assign jump         = (instruction[6:0] == 7'b1101111);
  assign jump_address = pc + imm;
endmodule


`timescale 1ns / 1ps
module INSTRUCTION_MEMORY(
    input  wire        clk,
    input  wire        reset,
    input  wire [31:0] pc,
    output wire [31:0] instruction
);
    // byte-addressable memory (each element is one byte)
    reg [7:0] mem [0:65535]; // size adjustable; example 64KB

    // RISC-V is little-endian
    assign instruction = { mem[pc + 3], mem[pc + 2], mem[pc + 1], mem[pc] };

    initial begin

        $readmemh("program.hex", mem);
    end
endmodule





`timescale 1ns / 1ps



module INSTRUCTION_FETCH(

    input  wire        clk,
    input  wire        reset,
    input  wire        stall,
    input  wire        branch,
    input  wire [31:0] branch_address,
    output reg  [31:0] pc,
    output wire [31:0] instruction
);

  wire [31:0] next_pc, jump_address;
  wire        jump;

  // Asynchronous reset for PC ensures no X states on deassertion
  always @(posedge clk or posedge reset) begin
    if (reset)        pc <= 32'b0;
    else if (!stall)  pc <= next_pc;
  end

  // Next-PC selection: branch, jump, or sequential PC+4
  PC_MUX mux (
    .pc(pc),
    .branch_address(branch_address),
    .jump_address(jump_address),
    .branch(branch),
    .jump(jump),
    .next_pc(next_pc)
  );

  // Detect jump instructions and compute target address
  jump_detector_and_jump_address det (
    .pc(pc),
    .instruction(instruction),
    .jump(jump),
    .jump_address(jump_address)
  );

  // Big-endian instruction memory with synchronous initialization
  INSTRUCTION_MEMORY i_mem (
    .clk(clk),
    .reset(reset),
    .pc(pc),
    .instruction(instruction)
  );
endmodule



`timescale 1ns / 1ps



module IF_ID(
input clk,
input reset,

input [31:0]if_pc,
input [31:0]if_instruction,

input stall,
input branch,

output reg [31:0]id_pc,
output reg [31:0]id_instruction
    );
    
    always @(posedge clk)
    begin
        if(reset)
        begin
            id_pc<=0;
            id_instruction<=0;
        end
        else
        begin
            if(!stall)
            begin
                if(branch)
                begin
                    id_pc<=0;
                    id_instruction<=0;
                end
                else if(!branch)
                begin
                    id_pc<=if_pc;
                    id_instruction<=if_instruction;
                end
            end
        end
    end
endmodule


`timescale 1ns / 1ps
module REGFILE(
    input           clk,
    input           reset,

    // read index ports
    input  [4:0]    s1,
    input  [4:0]    s2,
    input  [4:0]    read_rd,    // index to read old RD (for MAC)

    // write-back port
    input           reg_write,  // write enable from WB stage
    input  [4:0]    wb_rd,      // destination index from WB stage
    input  [31:0]   wb_data,    // data to be written at WB

    // read outputs
    output [31:0]   RS1,
    output [31:0]   RS2,
    output [31:0]   RD_OLD     // old value of destination (rd) used by MAC
);

    integer i;
    (* ram_style = "distributed" *) reg [31:0] GPP[0:31];

    // Combinational reads
    assign RS1   = GPP[s1];
    assign RS2   = GPP[s2];
    assign RD_OLD = GPP[read_rd];

    // Synchronous write-back
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            for (i = 0; i < 32; i = i + 1)
                GPP[i] <= 32'b0;
        end else begin
            if (reg_write && (wb_rd != 5'd0)) begin
                GPP[wb_rd] <= wb_data;
            end
        end
    end

endmodule

module CONTROL_UNIT(
input [6:0]opcode,

output reg [6:0]ex_control,//{pc_or_reg_or_0_select[2bits],imm_or_4_sel[2 bits],alu_op[2 bits],branch}
output reg [1:0]mem_control,//{mem_read,mem_write}
output reg [1:0]wb_control, //{mem_data_select,reg_write}

output reg unrecognized
    );
    
    //alu input 1
    parameter pc=     2'b00;
    parameter zero=   2'b01;
    parameter reg_s1= 2'b10;
   
    //alu input 2
    parameter reg_s2= 2'b00;
    parameter imm=    2'b01;
    parameter four=   2'b10;
    
    //alu op
    parameter ld_str= 2'b00;
    parameter brch=   2'b01; 
    parameter arith=  2'b10;
    parameter im_op = 2'b11;
    always@(*)
    begin
        case(opcode)
         7'b0110011://R type
         begin
         ex_control=   {reg_s1,reg_s2,arith,1'b0};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b1};
         unrecognized=1'b0;
         end
         
         7'b0010011://I type
         begin
         ex_control=   {reg_s1,imm,im_op,1'b0};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b1};
         unrecognized=1'b0;
         end
         
         7'b0000011://I type - Load
         begin
         ex_control=   {reg_s1,imm,ld_str,1'b0};
         mem_control=  {1'b1,1'b0};
         wb_control=   {1'b1,1'b1};   
         unrecognized=0;  
         end
         
         7'b0100011://S type
         begin
         ex_control=   {reg_s1,imm,ld_str,1'b0};
         mem_control=  {1'b0,1'b1};
         wb_control=   {1'b0,1'b0};
         unrecognized=0; 
         end
         
         7'b1100011://Branch type
         begin
         ex_control=   {reg_s1,reg_s2,brch,1'b1};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b0};  
         unrecognized=0;
         end
         
         7'b1101111://Jump and link
         begin
         ex_control=   {pc,four,ld_str,1'b0};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b1};  
         unrecognized=0;
         end
         
         7'b0110111://lui
         begin
         ex_control=   {zero,imm,ld_str,1'b0};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b1};    
         unrecognized=0;    
         end
         
         7'b0010111://AUIPC
         begin
         ex_control=   {pc,imm,ld_str,1'b0};
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b1};  
         unrecognized=0;
         end
         
         default:
         begin
         ex_control= 0;
         mem_control=  {1'b0,1'b0};
         wb_control=   {1'b0,1'b0}; 
         unrecognized=1'b1;
         end   
        endcase
    end
    
    
endmodule
  

