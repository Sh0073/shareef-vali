//////////////////////////////////////////////////////////////////////////////////
// Execute Stage with MAC / CNN / RV32I / RV32M support
//////////////////////////////////////////////////////////////////////////////////
module EXECUTE_STAGE(
    input  [31:0] pc,
    input  [31:0] rs1,        // forwarding applied
    input  [31:0] rs2,        // forwarding applied
    input  [31:0] imm,
    input  [6:0] ex_control,
    input  [2:0] funct_3,
    input  [6:0] funct_7,
    input  [31:0] rd_old,     // old RD value for MAC

    output [31:0] result,
    output [31:0] branch_address,
    output branch
);

    // Internal wires
    wire [31:0] alu_input_1;
    wire [31:0] alu_input_2;
    wire [4:0]  alu_control;     // 5-bit for MAC/CNN
    wire branch_cond;
    wire [1:0] alu_op = ex_control[2:1];

    // ALU input selection
    MUX_3_TO_1 m1(
        .input_1(pc),
        .input_2(32'd0),
        .input_3(rs1),
        .control(ex_control[6:5]),
        .selected_output(alu_input_1)
    );

    MUX_3_TO_1 m2(
        .input_1(rs2),
        .input_2(imm),
        .input_3(32'd4),
        .control(ex_control[4:3]),
        .selected_output(alu_input_2)
    );

    // ALU control
    ALU_CONTROL ac1(
        .alu_op(alu_op),
        .funct_3(funct_3),
        .funct_7(funct_7),
        .alu_control(alu_control)
    );

    // ALU
    ALU a1(
        .a(alu_input_1),
        .b(alu_input_2),
        .rd_in(rd_old),       // old RD for MAC
        .control(alu_control),
        .c(result)
    );

    // Branch condition
    BRANCH_CONDITION_CHECKER b1(
        .input1(alu_input_1),
        .input2(alu_input_2),
        .funct_3(funct_3),
        .branch_cond(branch_cond)
    );

    // Branch output
    assign branch = ex_control[0] & branch_cond;
    assign branch_address = pc + imm;

endmodule
  

